PORT=4000
FRONTEND_URL=http://localhost:3000

# ── Instagram auth (required for most requests) ──────────────────────────────
# RECOMMENDED: Export cookies while logged in at instagram.com
# 1. Install "Get cookies.txt LOCALLY" Chrome extension
# 2. Export cookies → save as cookies.txt in project root
#
# Alternative local dev:
# INSTAGRAM_COOKIES_BROWSER=chrome
#
# Alternative production:
# INSTAGRAM_SESSION_ID=your_session_id_here
