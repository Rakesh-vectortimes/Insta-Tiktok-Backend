PORT=4000
FRONTEND_URL=http://localhost:3000

# ── Scope ──────────────────────────────────────────────────────────────────────
# Public-only mode (no session/cookie fallback).
# Private accounts and stories are intentionally unsupported.

# ── Redis (required for production scale) ────────────────────────────────────
# REDIS_URL=redis://default:password@host:6379
# CACHE_TTL_SECONDS=900
# FORCE_ASYNC_JOBS=true
# SYNC_QUEUE_LIMIT=200
# WORKER_CONCURRENCY=5

# ── Cloudflare R2 / S3 CDN storage ───────────────────────────────────────────
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=...  (or R2_ACCESS_KEY)
# R2_SECRET_ACCESS_KEY=...  (or R2_SECRET_KEY)
# R2_BUCKET=video-downloads
# R2_PUBLIC_URL=https://cdn.yourdomain.com
# R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# VIDEO_CACHE_TTL_SECONDS=86400
# JOB_LOCK_TTL_SECONDS=600
# ANALYZE_RATE_LIMIT_MAX=20
# ANALYZE_RATE_LIMIT_WINDOW_MS=60000

# ── Rate limits ─────────────────────────────────────────────────────────────
# API_RATE_LIMIT_MAX=30
# API_RATE_LIMIT_WINDOW_MS=600000
# GLOBAL_MAX_CONCURRENT=200
